<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Tenant"
            android:textColor="@color/navy"
            android:textSize="20sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_tenant_search"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_input_field"
            android:hint="Search by name or email"
            android:paddingHorizontal="16dp"
            android:textColor="@color/slate" />

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/tv_search_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/navy"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_room_setup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="16dp">

            <EditText
                android:id="@+id/et_room_number"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Assign Unit/Room Number"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="10dp"
                android:textColor="@color/slate"
                android:textColorHint="#888888"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/et_base_rent"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Base Rent Amount (₱)"
                android:inputType="numberDecimal"
                android:background="@drawable/bg_input_field"
                android:paddingHorizontal="16dp"
                android:textColor="@color/slate"
                android:textColorHint="#888888"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_cancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:text="Cancel"
                android:textColor="@color/slate"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_add_tenant"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_marginStart="15dp"
                android:background="@drawable/bg_button"
                android:backgroundTint="@color/navy"
                android:paddingHorizontal="25dp"
                android:text="Search Account"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>