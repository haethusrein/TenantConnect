<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/card_bg"
    app:cardCornerRadius="15dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="15dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <FrameLayout
                android:id="@+id/avatar_container"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true">
                <TextView
                    android:id="@+id/tv_avatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_status_badge"
                    android:backgroundTint="#9E9E9E"
                    android:gravity="center"
                    android:text="T"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
                <ImageView
                    android:id="@+id/iv_tenant_photo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:layout_toEndOf="@id/avatar_container"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_name_room"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name • Room"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_due_amount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Due Date • Amount"
                    android:textColor="#9E9E9E"
                    android:textSize="10sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_status"
                android:layout_width="80dp"
                android:layout_height="30dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_status_badge"
                android:text="Unpaid"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textAllCaps="false"
                android:textStyle="bold" />
        </RelativeLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btn_action"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_status_badge"
            android:backgroundTint="#2E7D32"
            android:text="Mark as received"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
